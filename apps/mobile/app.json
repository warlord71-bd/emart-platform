{
  "expo": {
    "name": "eMart BD",
    "slug": "emart-bd",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "emartbd",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B1B2F"
    },
    "ios": {
      "bundleIdentifier": "com.emartbd.app",
      "supportsTablet": false
    },
    "android": {
      "package": "com.emartbd.app",
      "versionCode": 21,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E8739E"
      },
      "permissions": [
        "NOTIFICATIONS",
        "VIBRATE"
      ]
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#E8739E",
      "androidMode": "default"
    },
    "extra": {
      "eas": {
        "projectId": "8b0a3cc9-2926-4fe5-8504-6c549b5dedcd"
      },
      "privacyPolicyUrl": "https://e-mart.com.bd/privacy-policy",
      "termsUrl": "https://e-mart.com.bd/terms-conditions",
      "returnPolicyUrl": "https://e-mart.com.bd/return-policy",
      "shippingPolicyUrl": "https://e-mart.com.bd/shipping-policy"
    },
    "plugins": [
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      "expo-secure-store"
    ]
  }
}

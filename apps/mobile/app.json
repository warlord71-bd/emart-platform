{
  "expo": {
    "name": "eMart BD",
    "slug": "emart-bd",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "emartbd",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B1B2F"
    },
    "ios": {
      "bundleIdentifier": "com.emartbd.app",
      "supportsTablet": false
    },
    "android": {
      "package": "com.emartbd.app",
      "versionCode": 12,
      "permissions": [
        "VIBRATE"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "8b0a3cc9-2926-4fe5-8504-6c549b5dedcd"
      }
    },
    "plugins": [
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ]
  }
}

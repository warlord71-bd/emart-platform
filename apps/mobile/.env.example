# Public Emart mobile API base URL.
# Leave unset for production; the app defaults to https://e-mart.com.bd.
# Mobile builds must call the secure Next.js BFF routes and must never include
# WooCommerce consumer keys, secrets, or direct /wp-json/wc/v3 URLs.

EXPO_PUBLIC_EMART_API_URL=https://e-mart.com.bd

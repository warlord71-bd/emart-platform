# WooCommerce API Configuration
# Points to VPS WooCommerce at 5.189.188.229
# Get these from your WordPress Admin Dashboard:
# 1. Go to WooCommerce > Settings > Advanced > REST API
# 2. Create a new API key and get Consumer Key and Consumer Secret

REACT_APP_WOO_URL=http://5.189.188.229/wp-json/wc/v3
REACT_APP_WOO_CONSUMER_KEY=your_consumer_key_here
REACT_APP_WOO_CONSUMER_SECRET=your_consumer_secret_here

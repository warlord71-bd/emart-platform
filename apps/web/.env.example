# WooCommerce API Configuration
# Points to the public WooCommerce domain.
# Get API credentials from WordPress Admin Dashboard:
# 1. Go to WooCommerce > Settings > Advanced > REST API
# 2. Create a new API key and get Consumer Key and Consumer Secret

# Use the production domain so frontend URLs, canonicals, and API calls stay consistent.
NEXT_PUBLIC_WOO_URL=https://e-mart.com.bd
NEXT_PUBLIC_WC_API_URL=https://e-mart.com.bd/wp-json/wc/v3
# Server-side WooCommerce calls can use the local WordPress route to avoid Cloudflare/self-request overhead.
WOO_INTERNAL_URL=http://127.0.0.1
# Set this to the WordPress backend GraphQL endpoint after WPGraphQL/WooGraphQL are installed.
# Do not point this at the Next.js frontend if WordPress is served on a separate backend host.
WORDPRESS_GRAPHQL_URL=
WORDPRESS_GRAPHQL_TIMEOUT_MS=12000
WORDPRESS_GRAPHQL_PAGE_SIZE=1000
WORDPRESS_GRAPHQL_SITEMAP_TIMEOUT_MS=20000
WORDPRESS_GRAPHQL_SITEMAP_PAGE_SIZE=1000
WORDPRESS_GRAPHQL_SITEMAP_LIMIT=10000
WORDPRESS_GRAPHQL_SITEMAP_ENABLED=true
WOO_CONSUMER_KEY=your_consumer_key_here
WOO_CONSUMER_SECRET=your_consumer_secret_here

# Next.js Configuration
NEXT_PUBLIC_API_URL=https://e-mart.com.bd
NEXT_PUBLIC_SITE_URL=https://e-mart.com.bd
NODE_ENV=production

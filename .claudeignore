# Binary assets — not useful for Claude to read
*.png
*.jpg
*.jpeg
*.webp
*.gif
*.ico
*.svg
*.woff
*.woff2
*.ttf
*.eot
*.mp4
*.mp3
*.pdf
*.jfif

# Data files
*.csv
*.xlsx
*.gz
*.zip

# Mobile app — large assets, separate codebase
apps/mobile/

# Build artifacts
apps/web/.next/
apps/web/node_modules/
packages/*/node_modules/
node_modules/
.pnp/
.pnp.js

# Lock files — too large, not helpful
package-lock.json
yarn.lock
pnpm-lock.yaml

# Logs and temp
*.log
SESSION-LOG.md
apps/web/.agent-memory/

# Audit data
workspace/audit/
*.tsbuildinfo

# Large automation scripts in workspace/docs — readable on demand, not auto-context
# (reference markdown docs in workspace/docs/ remain accessible)
workspace/docs/*.py
workspace/docs/*.mjs
workspace/scripts/active/*.py

# Env files
.env*
